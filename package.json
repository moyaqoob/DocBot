{
  "name": "chatbot",
  "private": true,
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:backend": "cd apps/backend && uv run uvicorn main:app --reload",
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:backend\"",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "langchain": "^1.4.0",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5"
  }
}
